{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "danielortez/vamng",
    "type": "project",
    "description": "VAM Next-Gen",
    "keywords": [
        "virtual airline",
        "airlines",
        "airline management",
        "vam"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "bezhansalleh/filament-shield": "^4.2",
        "filament/filament": "5.6",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.14",
        "nunomaduro/essentials": "^1.2",
        "spatie/laravel-permission": "^7.3",
        "webpatser/laravel-countries": "^2.1"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "driftingly/rector-laravel": "^2.3",
        "fakerphp/faker": "^1.24",
        "fruitcake/laravel-debugbar": "^4.2",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "laravel/pao": "^1.0",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "pnpm install",
            "pnpm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "refactor": "rector",
        "lint": [
            "pint --parallel",
            "@refactor"
        ],
        "test:refactor": "rector --dry-run",
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "pnpm run lint:check",
            "pnpm run format:check",
            "pnpm run types:check",
            "@test"
        ],
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "test:lint": [
            "./vendor/bin/pint --parallel --test",
            "./vendor/bin/rector --dry-run"
        ],
        "test:types": "./vendor/bin/phpstan analyse --memory-limit=-1",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:unit": "pest"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable"
}
